{
  "version": 2,
  "buildCommand": "cd ../.. && npm run vercel-build-api",
  "builds": [
    {
      "src": "dist/apps/api/main.js",
      "use": "@vercel/node",
      "config": {
        "maxDuration": 30
      }
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "dist/apps/api/main.js"
    }
  ],
  "env": {
    "NODE_ENV": "production"
  },
  "functions": {
    "dist/apps/api/main.js": {
      "maxDuration": 30,
      "memory": 1024
    }
  }
}
